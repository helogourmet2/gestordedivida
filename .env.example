# ─── Firebase ────────────────────────────────────────────────────────────────
# Obtenha em: https://console.firebase.google.com
# Configurações do projeto → Seus apps → Web app → firebaseConfig

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# VAPID Key pública para Web Push
# Firebase Console → Cloud Messaging → Configuração da Web → Certificados push da Web
VITE_FIREBASE_VAPID_KEY=

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Obtenha em: https://supabase.com → seu projeto → Settings → API

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
